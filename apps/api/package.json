{
  "name": "@proarq/api",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env --watch src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "start": "bun run dist/index.js",
    "db:generate": "bun --env-file=../../.env drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env drizzle-kit migrate",
    "db:push": "bun --env-file=../../.env drizzle-kit push",
    "db:studio": "bun --env-file=../../.env drizzle-kit studio",
    "test": "bun --env-file=../../.env src/__test__/setup/seed.ts && bun --env-file=../../.env test src/__test__/unit/ src/__test__/middleware/ src/__test__/health.test.ts src/__test__/integration/",
    "db:seed": "bun --env-file=../../.env src/__test__/setup/seed.ts",
    "db:reset": "bun --env-file=../../.env src/infra/adapters/driven/database/reset.ts && bun run db:migrate && bun run db:seed"
  },
  "dependencies": {
    "@proarq/core": "workspace:*",
    "cors": "2.8.6",
    "csv-parse": "6.2.1",
    "decimal.js": "10.6.0",
    "deep-diff": "1.0.2",
    "drizzle-orm": "0.45.2",
    "express": "5.2.1",
    "jsonwebtoken": "9.0.3",
    "multer": "2.1.1",
    "pdfkit": "0.18.0",
    "postgres": "3.4.9",
    "swagger-ui-dist": "^5.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/cors": "2.8.19",
    "@types/deep-diff": "1.0.5",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.1.0",
    "@types/pdfkit": "0.17.6",
    "@types/supertest": "7.2.0",
    "@types/swagger-ui-express": "^4.0.0",
    "drizzle-kit": "0.31.10",
    "supertest": "7.2.2"
  }
}
