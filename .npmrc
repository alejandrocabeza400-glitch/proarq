# ═══════════════════════════════════════════
# 🛡️  SEGURIDAD — SUPPLY CHAIN
# ═══════════════════════════════════════════

# Falla la instalación si el package exige una versión de Node/Bun incompatible
engine-strict=true

# Verificar SSL siempre (protege contra Man-in-the-Middle)
strict-ssl=true

# Enviar autenticación aunque no la pidan explícitamente (evita token leak por redirects)
always-auth=true

# ═══════════════════════════════════════════
# 📦  COMPORTAMIENTO DE INSTALACIÓN
# ═══════════════════════════════════════════

# Guardar versiones exactas (sin ^, ~, ni >)
# "lodash": "4.17.21"  ✅  en vez de "lodash": "^4.17.21"
save-exact=true

# ═══════════════════════════════════════════
# 🔗  REGISTRO
# ═══════════════════════════════════════════

# URL del registro público
registry=https://registry.npmjs.org/

# Minimo tiempo de espera para considerar un paquete como "reciente" (en minutos)
minimumReleaseAge=1440

