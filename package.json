{
    "name": "proarq",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "dev": "bun run --filter '*' dev",
        "build": "bun run --filter '*' build",
        "test": "bun run --filter '*' test",
        "lint": "biome check --write --unsafe .",
        "lint:ci": "biome ci .",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "clean": "rm -rf packages/*/dist apps/*/dist",
        "db:seed": "bun run --filter '@proarq/api' db:seed",
        "db:generate": "bun run --filter '@proarq/api' db:generate",
        "db:migrate": "bun run --filter '@proarq/api' db:migrate",
        "db:push": "bun run --filter '@proarq/api' db:push",
        "db:studio": "bun run --filter '@proarq/api' db:studio"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.15",
        "@types/bun": "1.3.14"
    },
    "peerDependencies": {
        "typescript": "5"
    }
}
