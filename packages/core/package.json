{
        "name": "@proarq/core",
        "version": "0.0.1",
        "type": "module",
        "main": "src/index.ts",
        "types": "src/index.ts",
        "exports": {
                ".": "./src/index.ts",
                "./domain/*": "./src/domain/*.ts",
                "./application/*": "./src/application/*.ts",
                "./errors": "./src/errors/index.ts"
        },
        "scripts": {
                "build": "bun build ./src/index.ts --outdir ./dist --target bun",
                "dev": "bun --watch src/index.ts",
                "test": "bun test"
        },
        "dependencies": {
                "decimal.js": "10.6.0",
                "zod": "4.4.3"
        }
}
